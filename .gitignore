# Xcode
build/
DerivedData/
# The XcodeGen-generated project is ignored, EXCEPT the shared schemes — Xcode
# Cloud discovers buildable schemes from the committed repo, so a target with no
# committed scheme (e.g. AetherMac) can't be picked in a workflow. The scheme
# XML is deterministic from project.yml, so tracking it causes no drift.
*.xcodeproj/*
!*.xcodeproj/xcshareddata/
*.xcodeproj/xcshareddata/*
!*.xcodeproj/xcshareddata/xcschemes/
*.xcworkspace/

# Generated by XcodeGen from project.yml — regenerated on every `xcodegen generate`.
# Tracking them causes drift commits whenever project.yml changes.
Aether/SupportingFiles/*.plist
Aether/SupportingFiles/*.entitlements
AetherMac/SupportingFiles/*.plist
AetherMac/SupportingFiles/*.entitlements
xcuserdata/
*.xcuserstate
*.xcscmblueprint
*.xccheckout
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.swiftpm/
.build/
Package.resolved
Packages/

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# IDE / editor
.idea/
.vscode/
*.swp
*.swo

# Local config & secrets
*.local
.env
.env.*

# Generated / bootstrap caches
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# Coverage
*.gcda
*.gcno
*.profraw
coverage/

# Vendored VLCKit binary — fetched via scripts/fetch_vlckit.sh, not committed (~2.4 GB)
Vendor/VLCKit/VLCKit.xcframework
Vendor/VLCKit/*.tar.xz

# TMDb API key — local secret, set per developer / via Xcode Cloud
Config/Secrets.xcconfig
