    "On first connect iOS will ask for Local Network access — allow it, or the share can't be reached." : {
      "comment" : "A description of the SMB connection process.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Při prvním připojení si iOS vyžádá přístup k místní síti – povolte jej, jinak sdílení nebude dostupné."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Під час першого підключення iOS запитає доступ до локальної мережі — дозвольте його, інакше ресурс буде недоступним."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beim ersten Verbinden fragt iOS nach Zugriff auf das lokale Netzwerk – erlaube ihn, sonst ist die Freigabe nicht erreichbar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lors de la première connexion, iOS demandera l'accès au réseau local – autorisez-le, sinon le partage sera inaccessible."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En la primera conexión, iOS pedirá acceso a la red local: permítelo o no se podrá acceder al recurso compartido."
          }
        }
      }
    },
