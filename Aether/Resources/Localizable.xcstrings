    },
    "Matches posters & details for SMB and local files. Add your own key if matching isn't working." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Páruje plakáty a detaily pro SMB a místní soubory. Přidejte vlastní klíč, pokud párování nefunguje."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Зіставляє постери та деталі для SMB і локальних файлів. Додайте власний ключ, якщо зіставлення не працює."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ordnet Poster & Details für SMB- und lokale Dateien zu. Füge deinen eigenen Schlüssel hinzu, falls die Zuordnung nicht funktioniert."
          }
        },
        "fr" : {
          "stringUnit" : {
