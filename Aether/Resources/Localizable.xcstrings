    "A bold WATCHED tag over finished posters, on top of the dimming." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Výrazný štítek ZHLÉDNUTO přes dokoukané plakáty, navrch ztlumení."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Помітна позначка ПЕРЕГЛЯНУТО на завершених постерах, поверх затемнення."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine auffällige Markierung „GESEHEN“ über fertigen Postern, zusätzlich zur Abdunklung."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une étiquette « VU » bien visible sur les affiches terminées, en plus de l’assombrissement."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una etiqueta destacada de «VISTO» sobre los pósteres terminados, además del atenuado."
          }
        }
      }
    },
    "A readable snapshot of sources, library, downloads, and cache." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Čitelný přehled zdrojů, knihovny, stahování a mezipaměti."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Читабельний знімок джерел, бібліотеки, завантажень і кешу."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine übersichtliche Momentaufnahme von Quellen, Mediathek, Downloads und Cache."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un aperçu clair des sources, de la bibliothèque, des téléchargements et du cache."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una instantánea legible de fuentes, biblioteca, descargas y caché."
          }
        }
      }
    },
