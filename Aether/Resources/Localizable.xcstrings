    "Mark titles you own that are also on Netflix, and surface Netflix-only titles in Discover and Search. Aether links out — it never streams Netflix." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Označí tituly z vaší knihovny, které jsou také na Netflixu, a zobrazí tituly dostupné jen na Netflixu v Objevování a Hledání. Aether jen odkáže ven — sám Netflix nepřehrává."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Позначає наявні у вас тайтли, які також є на Netflix, і показує тайтли лише з Netflix у Огляді та Пошуку. Aether лише веде назовні — він ніколи не відтворює Netflix."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Markiere Titel in deinem Besitz, die auch auf Netflix verfügbar sind, und zeige Netflix-exklusive Titel in Entdecken und der Suche. Aether verlinkt nur – es streamt Netflix nie."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Identifiez les titres que vous possédez qui sont aussi sur Netflix, et faites apparaître les titres exclusifs à Netflix dans Découvrir et la recherche. Aether ne fait que rediriger — il ne diffuse jamais Netflix."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Marca los títulos que posees que también están en Netflix y muestra los títulos exclusivos de Netflix en Descubrir y Buscar. Aether solo enlaza: nunca reproduce Netflix."
          }
        }
      }
    },
    "Match" : {
      "localizations" : {
