    "A bold WATCHED tag over finished posters, on top of the dimming." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Výrazný štítek ZHLÉDNUTO přes dokoukané plakáty, navrch ztlumení."
