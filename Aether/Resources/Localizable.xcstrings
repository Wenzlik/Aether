    "Match the system, or force Dark or Light." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Podle systému, nebo vynutit tmavý či světlý."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "За системою або примусово темна чи світла."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "An das System anpassen oder Dunkel bzw. Hell erzwingen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suivre le système, ou forcer le mode sombre ou clair."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Igualar el sistema o forzar el modo oscuro o claro."
          }
