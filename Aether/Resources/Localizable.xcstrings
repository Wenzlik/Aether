    },
    "Aether asks Plex which servers your account can reach." : {
      "comment" : "A description of Plex's discovery process.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aether se zeptá Plexu, které servery jsou pro váš účet dostupné."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aether запитує Plex, до яких серверів має доступ ваш обліковий запис."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aether fragt Plex, welche Server für dein Konto erreichbar sind."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aether demande à Plex quels serveurs votre compte peut atteindre."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aether le pregunta a Plex a qué servidores puede acceder tu cuenta."
          }
        }
      }
    },
    "Aether is a native player for your own media — Plex, Jellyfin, and files on your device — built for Apple platforms with one cinematic interface across iPhone, iPad, Apple TV, and Vision Pro. No catalogue to rent, no account to sell: just your library, played well." : {
      "comment" : "A description of Aether, a media player for Apple devices.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aether je nativní přehrávač pro vaše vlastní média — Plex, Jellyfin a soubory v zařízení — vytvořený pro platformy Apple s jednotným filmovým rozhraním na iPhonu, iPadu, Apple TV a Vision Pro. Žádný katalog k pronájmu, žádný účet na prodej: jen vaše knihovna, dobře přehraná."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aether — це рідний плеєр для вашого власного медіа — Plex, Jellyfin і файлів на вашому пристрої — створений для платформ Apple з єдиним кінематографічним інтерфейсом на iPhone, iPad, Apple TV та Vision Pro. Жодного каталогу в оренду, жодного облікового запису на продаж: лише ваша бібліотека, відтворена якісно."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aether ist ein nativer Player für deine eigenen Medien – Plex, Jellyfin und Dateien auf deinem Gerät – entwickelt für Apple-Plattformen mit einer cineastischen Oberfläche auf iPhone, iPad, Apple TV und Vision Pro. Kein Katalog zum Mieten, kein Konto zum Verkaufen: einfach deine Mediathek, gut wiedergegeben."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aether est un lecteur natif pour vos propres médias – Plex, Jellyfin et les fichiers sur votre appareil – conçu pour les plateformes Apple avec une interface cinématographique unique sur iPhone, iPad, Apple TV et Vision Pro. Aucun catalogue à louer, aucun compte à vendre : juste votre bibliothèque, bien lue."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aether es un reproductor nativo para tus propios medios: Plex, Jellyfin y archivos en tu dispositivo, creado para las plataformas Apple con una interfaz cinematográfica unificada en iPhone, iPad, Apple TV y Vision Pro. Sin catálogo que alquilar, sin cuenta que vender: solo tu biblioteca, reproducida como se merece."
          }
        }
      }
    },
    "Aether links out to Netflix — it doesn't stream it here." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aether odkazuje na Netflix — nepřehrává ho zde."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aether веде на Netflix — він не відтворює його тут."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aether verlinkt auf Netflix – es wird nicht hier wiedergegeben."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aether renvoie vers Netflix – la lecture ne se fait pas ici."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aether enlaza con Netflix; no lo reproduce aquí."
          }
