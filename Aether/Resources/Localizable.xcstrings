    },
    "“Original” isn’t offered here — this title’s format can’t play offline in Cinema on Vision Pro. Pick a quality to download a compatible copy." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„Original“ wird hier nicht angeboten – das Format dieses Titels kann offline in Cinema auf Vision Pro nicht abgespielt werden. Wähle eine Qualität, um eine kompatible Kopie herunterzuladen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« Original » n'est pas proposé ici — le format de ce titre ne peut pas être lu hors ligne dans Cinema sur Vision Pro. Choisissez une qualité pour télécharger une copie compatible."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aquí no se ofrece «Original»: el formato de este título no se puede reproducir sin conexión en Cinema en Vision Pro. Elige una calidad para descargar una copia compatible."
          }
        }
      }
    },
