    "Choose a different Plex Home profile — each has its own watch history and libraries." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zvolte jiný profil Plex Home — každý má vlastní historii sledování a knihovny."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Виберіть інший профіль Plex Home — кожен має власну історію переглядів і бібліотеки."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein anderes Plex Home-Profil wählen – jedes hat seinen eigenen Wiedergabeverlauf und eigene Mediatheken."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choisissez un autre profil Plex Home — chacun a son propre historique et ses propres bibliothèques."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige otro perfil de Plex Home: cada uno tiene su propio historial y sus bibliotecas."
          }
        }
      }
    },
    "·" : {
      "comment" : "A separator between two values.",
      "isCommentAutoGenerated" : true,
