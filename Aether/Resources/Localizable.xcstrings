    "You can sign back in any time. Downloads and settings stay on this device." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kannst dich jederzeit wieder anmelden. Downloads und Einstellungen bleiben auf diesem Gerät."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous pouvez vous reconnecter à tout moment. Les téléchargements et les réglages restent sur cet appareil."
          }
        },
        "es" : {
          "stringUnit" : {
