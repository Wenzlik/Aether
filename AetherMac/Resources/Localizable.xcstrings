    "Leave the selection empty to scan every share on this server.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Necháš-li výběr prázdný, prohledá se každý share na tomto serveru."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Якщо залишити вибір порожнім, скануватиметься кожен спільний ресурс на цьому сервері."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lasse die Auswahl leer, um jede Freigabe auf diesem Server zu durchsuchen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Laissez la sélection vide pour analyser tous les partages de ce serveur."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Deja la selección vacía para analizar todos los recursos compartidos de este servidor."
          }
        }
      }
    },
    "Leave the username and password empty to connect as a guest. The share is mounted on this Mac and scanned for movies and shows.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro připojení jako host nech uživatelské jméno a heslo prázdné. Složka se připojí k tomuto Macu a prohledá se na filmy a seriály."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lasse Benutzername und Passwort leer, um als Gast zu verbinden. Die Freigabe wird auf diesem Mac aktiviert und nach Filmen und Serien durchsucht."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Laissez le nom d’utilisateur et le mot de passe vides pour vous connecter en tant qu’invité. Le partage est monté sur ce Mac et analysé à la recherche de films et de séries."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Deja el nombre de usuario y la contraseña vacíos para conectarte como invitado. El recurso compartido se monta en este Mac y se analiza en busca de películas y series."
          }
        }
      }
    },
