    "Applied to every title you open. You can still change the audio, subtitles, and quality for a single title on its detail screen.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Použije se na každý titul, který otevřeš. Zvuk, titulky a kvalitu můžeš pořád změnit u konkrétního titulu na jeho detailu."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wird auf jeden Titel angewendet, den du öffnest. Audio, Untertitel und Qualität kannst du für einen einzelnen Titel weiterhin auf dessen Detailseite ändern."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appliqué à chaque titre que vous ouvrez. Vous pouvez toujours modifier l'audio, les sous-titres et la qualité pour un titre donné sur sa page de détails."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se aplica a cada título que abres. Aún puedes cambiar el audio, los subtítulos y la calidad de un título concreto en su pantalla de detalles."
          }
        }
      }
    },
