        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Slouží ke stažení posterů a popisů pro tvou lokální knihovnu. Nech prázdné pro klíč zabudovaný v aplikaci, nebo vlož vlastní z themoviedb.org."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wird verwendet, um Poster und Beschreibungen für deine lokale Mediathek abzurufen. Leer lassen, um den in der App integrierten Schlüssel zu verwenden, oder füge deinen eigenen von themoviedb.org ein."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisé pour récupérer les affiches et les descriptions de votre bibliothèque locale. Laissez vide pour utiliser la clé intégrée à l'app, ou collez la vôtre depuis themoviedb.org."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se usa para obtener carteles y descripciones de tu biblioteca local. Déjalo en blanco para usar la clave integrada en la app, o pega la tuya desde themoviedb.org."
          }
        }
      }
    },
    "Used to fetch posters and descriptions for your local library. Leave blank to use the key built into the app, or paste your own from themoviedb.org. Press Return to apply.": {
      "comment": "Footer text under the TMDb API key field.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Slouží k načítání plakátů a popisů pro vaši místní knihovnu. Nechte prázdné pro použití klíče vestavěného v aplikaci, nebo vložte vlastní z themoviedb.org. Potvrďte klávesou Return."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wird verwendet, um Poster und Beschreibungen für deine lokale Mediathek abzurufen. Leer lassen, um den in der App integrierten Schlüssel zu verwenden, oder füge deinen eigenen von themoviedb.org ein. Drücke die Eingabetaste, um zu übernehmen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisé pour récupérer les affiches et les descriptions de votre bibliothèque locale. Laissez vide pour utiliser la clé intégrée à l'app, ou collez la vôtre depuis themoviedb.org. Appuyez sur Retour pour appliquer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se usa para obtener carteles y descripciones de tu biblioteca local. Déjalo en blanco para usar la clave integrada en la app, o pega la tuya desde themoviedb.org. Pulsa Retorno para aplicar."
          }
        }
      }
    },
    "Used to fetch posters and descriptions for your local library. Leave the built-in key, or paste your own from themoviedb.org — it's verified against TMDb before saving, then hidden.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Slouží k načítání plakátů a popisů pro vaši místní knihovnu. Ponechte vestavěný klíč, nebo vložte vlastní z themoviedb.org — před uložením se ověří proti TMDb a poté se skryje."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wird verwendet, um Poster und Beschreibungen für deine lokale Mediathek abzurufen. Behalte den integrierten Schlüssel oder füge deinen eigenen von themoviedb.org ein — er wird vor dem Speichern bei TMDb überprüft und dann ausgeblendet."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisé pour récupérer les affiches et les descriptions de votre bibliothèque locale. Conservez la clé intégrée, ou collez la vôtre depuis themoviedb.org — elle est vérifiée auprès de TMDb avant d'être enregistrée, puis masquée."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se usa para obtener carteles y descripciones de tu biblioteca local. Conserva la clave integrada, o pega la tuya desde themoviedb.org — se verifica con TMDb antes de guardarla y luego se oculta."
          }
        }
      }
    },
