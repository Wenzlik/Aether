    "Pick folders on this Mac or a mounted network share. Aether scans them for movies and shows and adds them to your library.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyber složky na tomto Macu nebo na připojeném síťovém disku. Aether je prohledá na filmy a seriály a přidá je do knihovny."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle Ordner auf diesem Mac oder einer eingebundenen Netzwerkfreigabe. Aether durchsucht sie nach Filmen und Serien und fügt sie deiner Mediathek hinzu."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez des dossiers sur ce Mac ou un partage réseau monté. Aether y recherche des films et des séries et les ajoute à votre bibliothèque."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige carpetas en este Mac o en un recurso de red montado. Aether las analiza en busca de películas y series y las añade a tu biblioteca."
          }
        }
      }
    },
