          }
        }
      }
    },
    "Nothing here yet": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zatím tu nic není"
          }
        }
      }
    },
    "Connect Plex or Jellyfin in Settings to browse your library.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Připoj Plex nebo Jellyfin v Nastavení a procházej svou knihovnu."
          }
        }
      }
    },
    "Applied to every title you open. You can still change the audio, subtitles, and quality for a single title on its detail screen.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Použije se na každý titul, který otevřeš. Zvuk, titulky a kvalitu můžeš pořád změnit u konkrétního titulu na jeho detailu."
          }
        }
      }
    },
    "Recently Added, Recently Released, and Top Rated show what's still ahead. Your Library always shows everything.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nedávno přidané, Nedávno vydané a Nejlépe hodnocené ukazují, co tě teprve čeká. Knihovna vždy ukáže všechno."
          }
        }
      }
    },
    "Couldn't connect": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Připojení se nezdařilo"
          }
        }
      }
    },
    "Try Again": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zkusit znovu"
          }
        }
      }
    },
    "Waiting for you to authorize…": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Čekání na autorizaci…"
          }
        }
      }
    },
    "Enter this code at plex.tv/link:": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zadej tento kód na plex.tv/link:"
          }
        }
      }
    },
    "Open plex.tv/link": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Otevřít plex.tv/link"
          }
        }
      }
    },
    "Approve this code in Jellyfin\n(Dashboard ▸ Quick Connect, or a signed-in client):": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Schval tento kód v Jellyfinu\n(Dashboard ▸ Quick Connect, nebo přihlášený klient):"
          }
        }
      }
    },
    "Personal media, beautifully played.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Osobní média, krásně přehraná."
          }
        }
      }
    },
    "Add Folder…": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přidat složku…"
          }
        }
      }
    },
