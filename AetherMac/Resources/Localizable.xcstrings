    "System follows your Mac's Light/Dark setting. Light mode is still being polished.": {
      "comment": "A description of the system-wide light/dark mode setting.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Systém se řídí nastavením světlého/tmavého režimu vašeho Macu. Světlý režim se stále dolaďuje."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "System folgt der Hell-/Dunkel-Einstellung deines Macs. Der helle Modus wird noch verbessert."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Système suit le réglage clair/sombre de votre Mac. Le mode clair est encore en cours de peaufinage."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistema sigue el ajuste claro/oscuro de tu Mac. El modo claro todavía se está puliendo."
