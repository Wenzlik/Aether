{
  "sourceLanguage": "en",
  "strings": {
    "Because you watched %@": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Protože jste viděli %@"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Weil du %@ gesehen hast"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Porque viste %@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Parce que vous avez regardé %@"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Тому що ви дивилися %@"
          }
        }
      }
